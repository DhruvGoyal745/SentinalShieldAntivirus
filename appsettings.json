{
  "ConnectionStrings": {
    "PlatformDb": "Server=.\\SQLEXPRESS;Integrated Security=true;TrustServerCertificate=true;Initial Catalog=SentinelShieldDb"
  },
  "AntivirusPlatform": {
    "DataRoot": "Data",
    "QuarantineRoot": "Data\\Quarantine",
    "LogsRoot": "Data\\Logs",
    "MaxHeuristicFiles": 1500,
    "DefaultRequestedBy": "desktop-user",
    "RealtimeWatcherEnabled": true,
    "WatchRoots": [
      "%USERPROFILE%\\Downloads",
      "%USERPROFILE%\\Desktop",
      "%USERPROFILE%\\Documents",
      "%TEMP%",
      "%APPDATA%\\Microsoft\\Windows\\Start Menu\\Programs\\Startup"
    ],
    "FileEventDebounceSeconds": 5,
    "MaxFileScanBytes": 104857600,
    "MaxHashComputationBytes": 33554432,
    "MaxContentInspectionBytes": 131072,
    "MaxParallelScanWorkers": 4,
    "ProgressPersistEveryFiles": 25,
    "ProgressPersistMinIntervalMs": 750,
    "UseInHouseScanners": true,
    "SignaturePackRoot": "Data\\SignaturePacks",
    "ParserCompatibilityVersion": "parser-1.0.0",
    "SignatureCompilerVersion": "sigc-1.0.0"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
