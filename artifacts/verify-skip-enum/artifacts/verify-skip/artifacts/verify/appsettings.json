{
  "ConnectionStrings": {
    "PlatformDb": "Server=(localdb)\\MSSQLLocalDB;Integrated Security=true;TrustServerCertificate=true;Initial Catalog=SentinelShieldDb"
  },
  "AntivirusPlatform": {
    "QuarantineRoot": "Data\\Quarantine",
    "MaxHeuristicFiles": 1500,
    "DefaultRequestedBy": "desktop-user",
    "RealtimeWatcherEnabled": true,
    "WatchRoots": [
      "%USERPROFILE%\\Downloads",
      "%USERPROFILE%\\Desktop",
      "%USERPROFILE%\\Documents",
      "%TEMP%",
      "%APPDATA%\\Microsoft\\Windows\\Start Menu\\Programs\\Startup"
    ],
    "FileEventDebounceSeconds": 5,
    "MaxFileScanBytes": 104857600,
    "UseOpenSourceScanners": true,
    "YaraExecutablePath": "Tools\\Yara\\yara64.exe",
    "YaraRulesPath": "Rules\\Yara\\starter-rules.yar",
    "YaraRulesCompiled": false,
    "ClamAvExecutablePath": "Tools\\ClamAV\\clamscan.exe",
    "ClamAvDaemonExecutablePath": "Tools\\ClamAV\\clamdscan.exe",
    "PreferClamAvDaemon": false,
    "UseNativeEngineBridge": true,
    "UseManagedNativeEngineFallback": true,
    "NativeEngineDaemonPath": "NativeEngine\\artifacts\\sentinel-engine-daemon.exe",
    "NativeEnginePipeName": "sentinel-engine-daemon",
    "NativeEngineSocketPath": "/tmp/sentinel-engine-daemon.sock",
    "SignaturePackRoot": "Data\\SignaturePacks",
    "ParserCompatibilityVersion": "parser-1.0.0",
    "SignatureCompilerVersion": "sigc-1.0.0"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
