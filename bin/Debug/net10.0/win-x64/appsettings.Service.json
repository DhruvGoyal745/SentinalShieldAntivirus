{
  "ConnectionStrings": {
    "PlatformDb": "Server=.\\SQLEXPRESS;Integrated Security=true;TrustServerCertificate=true;Initial Catalog=SentinelShieldDb;Connect Timeout=10"
  },
  "Kestrel": {
    "Endpoints": {
      "Localhost": {
        "Url": "http://127.0.0.1:5100"
      }
    }
  },
  "AntivirusPlatform": {
    "QuarantineRoot": "C:\\ProgramData\\SentinelShield\\Quarantine",
    "SignaturePackRoot": "C:\\ProgramData\\SentinelShield\\SignaturePacks",
    "RealtimeWatcherEnabled": true,
    "UseInHouseScanners": true,
    "UseNativeEngineBridge": true,
    "UseManagedNativeEngineFallback": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "EventLog": {
      "SourceName": "Sentinel Shield Antivirus",
      "LogName": "Application",
      "LogLevel": {
        "Default": "Warning"
      }
    }
  }
}
